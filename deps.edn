{:aliases  {:dev {:extra-paths ["development/src"]
                  :extra-deps {org.clojure/clojure {:mvn/version "1.11.1"}
                               mono/schema {:local/root "components/schema"}
                               mono/resourcekit {:local/root "components/resourcekit"}
                               mono/content-negotiation {:local/root "components/content-negotiation"}
                               mono/rts-data {:local/root "components/rts-data"}
                               mono/rose-api {:local/root "bases/rose-api"}
                               mono/rts-api {:local/root "bases/rts-api"}
                               mono/rts-data-deploy {:local/root "bases/rts-data-deploy"}}}

            :test {:extra-paths ["components/schema"
                                 "components/resourcekit"
                                 "components/content-negotiation"
                                 "bases/rose-api"
                                 "bases/rts-api"]}

            :poly {:main-opts ["-m" "polylith.clj.core.poly-cli.core"]
                   :extra-deps {polyfy/polylith
                                {:git/url   "https://github.com/polyfy/polylith"
                                 :sha       "dc87aa3b4be5496488d70c78e1db37ad3a9ba52f"
                                 :deps/root "projects/poly"}}}}}
